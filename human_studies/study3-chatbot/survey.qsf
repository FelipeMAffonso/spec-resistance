taVisibility":[],"AnalyzeText":false},{"Description":"response_12","Type":"Recipient","Field":"response_12","VariableType":"String","DataVisibility":[],"AnalyzeText":false},{"Description":"response_13","Type":"Recipient","Field":"response_13","VariableType":"String","DataVisibility":[],"AnalyzeText":false},{"Description":"response_14","Type":"Recipient","Field":"response_14","VariableType":"String","DataVisibility":[],"AnalyzeText":false},{"Description":"response_15","Type":"Recipient","Field":"response_15","VariableType":"String","DataVisibility":[],"AnalyzeText":false},{"Description":"response_16","Type":"Recipient","Field":"response_16","VariableType":"String","DataVisibility":[],"AnalyzeText":false},{"Description":"response_17","Type":"Recipient","Field":"response_17","VariableType":"String","DataVisibility":[],"AnalyzeText":false},{"Description":"response_18","Type":"Recipient","Field":"response_18","VariableType":"String","DataVisibility":[],"AnalyzeText":false},{"Description":"response_19","Type":"Recipient","Field":"response_19","VariableType":"String","DataVisibility":[],"AnalyzeText":false},{"Description":"response_20","Type":"Recipient","Field":"response_20","VariableType":"String","DataVisibility":[],"AnalyzeText":false}]},{"Type":"Block","ID":"BL_dg4yQa3B92PRYCW","FlowID":"FL_2","Autofill":[]}],"Properties":{"Count":5}}},{"SurveyID":"SV_cO7ZnS6te5H7ASa","Element":"PL","PrimaryAttribute":"Preview Link","SecondaryAttribute":null,"TertiaryAttribute":null,"Payload":{"PreviewType":"Brand","PreviewID":"dbd6872d-b505-43e2-aabc-117b405479f6"}},{"SurveyID":"SV_cO7ZnS6te5H7ASa","Element":"PROJ","PrimaryAttribute":"CORE","SecondaryAttribute":null,"TertiaryAttribute":"1.1.0","Payload":{"ProjectCategory":"CORE","SchemaVersion":"1.1.0"}},{"SurveyID":"SV_cO7ZnS6te5H7ASa","Element":"QC","PrimaryAttribute":"Survey Question Count","SecondaryAttribute":"3","TertiaryAttribute":null,"Payload":null},{"SurveyID":"SV_cO7ZnS6te5H7ASa","Element":"RS","PrimaryAttribute":"RS_4ME4wY97red5A3k","SecondaryAttribute":"Default Response Set","TertiaryAttribute":null,"Payload":null},{"SurveyID":"SV_cO7ZnS6te5H7ASa","Element":"SCO","PrimaryAttribute":"Scoring","SecondaryAttribute":null,"TertiaryAttribute":null,"Payload":{"ScoringCategories":[],"ScoringCategoryGroups":[],"ScoringSummaryCategory":null,"ScoringSummaryAfterQuestions":0,"ScoringSummaryAfterSurvey":0,"DefaultScoringCategory":null,"AutoScoringCategory":null}},{"SurveyID":"SV_cO7ZnS6te5H7ASa","Element":"SO","PrimaryAttribute":"Survey Options","SecondaryAttribute":null,"TertiaryAttribute":null,"Payload":{"BackButton":"false","SaveAndContinue":"true","SurveyProtection":"PublicSurvey","BallotBoxStuffingPrevention":"false","NoIndex":"Yes","SecureResponseFiles":"true","SurveyExpiration":"None","SurveyTermination":"DefaultMessage","Header":"","Footer":"","ProgressBarDisplay":"None","PartialData":"+1 week","ValidationMessage":"","PreviousButton":"","NextButton":"","SurveyTitle":"Qualtrics Survey | Qualtrics Experience Management","SkinLibrary":"insead","SkinType":"templated","Skin":{"brandingId":null,"templateId":"*base","overrides":null},"NewScoring":1,"SurveyMetaDescription":"The most powerful, simple and trusted way to gather experience data. Start your journey to experience management and try a free account today.","CustomStyles":{"customCSS":"body {\n  margin: 0;\n  padding: 0;\n}\n#chat-container {\n  width: 100%;\n  height: 120vh;\n  max-height: 400px;\n  border: 1px solid #ddd;\n  border-radius: 10px;\n  overflow: hidden;\n  display: flex;\n  flex-direction: column;\n  justify-content: space-between;\n  margin: 0 auto;\n}\n#chat-history-1 {\n  height: calc(100% - 56px);\n  overflow-y: auto;\n  padding: 10px;\n}\n.message {\n  display: flex;\n  flex-direction: column;\n  margin: 10px 0;\n}\n.user-message {\n  margin-left: auto;\n  max-width: 70%;\n  padding: 0.5rem .875rem;\n  border-radius: 12px 12px 0 12px;\n  line-height: 1.5;\n  display: flex;\n  flex-direction: column;\n  word-wrap: break-word;\n  position: relative;\n  width: fit-content;\n  font-family: helvetica;\n  background-color: #007AFF;\n  color: white;\n}\n.bot-message {\n  max-width: 70%;\n  padding: 0.5rem .875rem;\n  border-radius: 12px 12px 12px 0;\n  line-height: 1.5;\n  display: flex;\n  flex-direction: column;\n  word-wrap: break-word;\n  position: relative;\n  width: fit-content;\n  font-family: helvetica;\n  background-color: #F2F2F2;\n  color: #333;\n}\n#chat-input {\n  display: flex;\n  align-items: center;\n  padding: 10px;\n  background-color: #F9F9F9;\n  width: 100%;\n  box-sizing: border-box;\n}\n#message-input-1 {\n  flex: 1;\n  margin-right: 10px;\n  padding: 10px;\n  border: 1px solid #ddd;\n  border-radius: 5px;\n  width: calc(100% - 80px);\n  box-sizing: border-box;\n}\n#send-button-1 {\n  background-color: #007AFF;\n  border: none;\n  color: white;\n  padding: 10px;\n  border-radius: 5px;\n  cursor: pointer;\n  transition: background-color 0.3s ease;\n}\n#send-button-1:hover {\n  background-color: #0066CC;\n}"}}},{"SurveyID":"SV_cO7ZnS6te5H7ASa","Element":"SQ","PrimaryAttribute":"QID1","SecondaryAttribute":"\u00a0 Send","TertiaryAttribute":null,"Payload":{"QuestionText":"<div id=\"chat-container\">\n<div id=\"chat-history-1\">&nbsp;<\/div>\n\n<div id=\"chat-input\"><input id=\"message-input-1\" placeholder=\"Type your message here...\" type=\"text\"><button id=\"send-button-1\">Send<\/button><\/div>\n<\/div>","DefaultChoices":false,"DataExportTag":"Q1","QuestionID":"QID1","QuestionType":"DB","Selector":"TB","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText"},"QuestionDescription":"\u00a0 Send","ChoiceOrder":[],"Validation":{"Settings":{"Type":"None"}},"GradingData":[],"Language":[],"NextChoiceId":4,"NextAnswerId":1,"QuestionJS":"Qualtrics.SurveyEngine.addOnload(function() {\n\n});\n\nQualtrics.SurveyEngine.addOnReady(function() {\n  \/\/ This function will be executed when the survey is ready to be displayed\n  \/\/ Initialize conversation history array\n  var conversationHistory1 = [];\n  var promptCounter1 = 0;\n  var responseCounter1 = 0;\n\n  \/\/ Function to display bot's message instantly\n  function displayInstantly(botMessage, delay) {\n    setTimeout(function() {\n      var chatHistory = document.getElementById(\"chat-history-1\");\n\n      var messageElement = document.createElement(\"div\");\n      messageElement.classList.add(\"message\", \"bot-message\");\n      messageElement.textContent = botMessage;\n\n      chatHistory.appendChild(messageElement);\n      chatHistory.scrollTop = chatHistory.scrollHeight;\n    }, delay);\n  }\n\n  \/\/ Function to send a message to the server (via your proxy)\n  function sendMessage() {\n    \/\/ Get the user's message from the input field\n    var messageInput = document.getElementById(\"message-input-1\");\n    if (!messageInput) return;\n    var message = (messageInput.value || \"\").trim();\n\n    if (message) {\n      \/\/ Add user's message to conversation history and store it in a variable\n      promptCounter1++;\n      var userPrompt = 'msg_' + promptCounter1;\n      Qualtrics.SurveyEngine.setEmbeddedData(userPrompt, message);\n      conversationHistory1.push({ role: \"user\", content: message });\n\n      \/\/ Display user's message in the chat history\n      var chatHistory = document.getElementById(\"chat-history-1\");\n      if (chatHistory) {\n        var messageElement = document.createElement(\"div\");\n        messageElement.classList.add(\"message\", \"user-message\");\n        messageElement.textContent = message;\n        chatHistory.appendChild(messageElement);\n        chatHistory.scrollTop = chatHistory.scrollHeight;\n      }\n\t\t\n      \/\/ Send user's message to the server and display response (PROXY, no API key in browser)\n      fetch(\"INSERT YOUR PROXY LINK HERE\", {\n        method: \"POST\",\n        headers: { \"Content-Type\": \"application\/json\" },\n        body: JSON.stringify({\n          \/\/ Proxy expects this shape and returns { text }\n          prompt: message,\n          system: \"${e:\/\/Field\/prompt}\",\n          history: conversationHistory1,\n          model: \"${e:\/\/Field\/model}\" || \"gpt-4o-mini\",\n          \/\/ Optional tuning (your proxy can read these if supported server-side)\n          temperature: parseFloat(\"${e:\/\/Field\/temperature}\"),\n          max_tokens: parseInt(\"${e:\/\/Field\/max_tokens}\", 10)\n        })\n      })\n      .then(response => response.json())\n      .then(data => {\n          \/\/ Proxy returns { text: \"...\" }\n          var botMessage = (data && data.text ? data.text.trim() : \"(no response)\");\n\n          \/\/ Add bot's message to conversation history and store it in a variable\n          responseCounter1++;\n          var aiResponse = 'response_' + responseCounter1;\n          Qualtrics.SurveyEngine.setEmbeddedData(aiResponse, botMessage);\n          conversationHistory1.push({ role: \"assistant\", content: botMessage });\n\n          \/\/ Count the number of words in the botMessage\n          var wordCount = botMessage.split(\/\\s+\/).filter(Boolean).length;\n\n          var delayPerWord = parseInt(\"${e:\/\/Field\/delay_per_word}\", 10) || 0;\n          \/\/ Calculate the total delay based on the number of words\n          var totalDelay = wordCount * delayPerWord;\n          \/\/ Display bot's message in the chat history with the calculated delay\n          displayInstantly(botMessage, totalDelay);\n      })\n      .catch(error => console.error(\"Proxy fetch error:\", error));\n\n      \/\/ Clear input field\n      messageInput.value = \"\";\n    }\n  }\n\n  \/\/ Add event listener to send button\n  var sendButton = document.getElementById(\"send-button-1\");\n  if (sendButton) sendButton.addEventListener(\"click\", sendMessage);\n\n  \/\/ Listen for \"keydown\" event on message input element\n  var messageInput = document.getElementById(\"message-input-1\");\n  if (messageInput) {\n    messageInput.addEventListener(\"keydown\", function(event) {\n      if (event.key === \"Enter\") {\n        event.preventDefault(); \/\/ prevent Qualtrics from advancing the page\n        sendMessage();\n      }\n    });\n  }\n});\n\nQualtrics.SurveyEngine.addOnUnload(function() {\n  \/\/ This function will be executed when the page is unloaded\n});"}},{"SurveyID":"SV_cO7ZnS6te5H7ASa","Element":"STAT","PrimaryAttribute":"Survey Statistics","SecondaryAttribute":null,"TertiaryAttribute":null,"Payload":{"MobileCompatible":true,"ID":"Survey Statistics"}}]}