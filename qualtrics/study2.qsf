ype":"Brand","PreviewID":"37927e60-c39d-4e44-8419-6e7a221d214a"}},{"SurveyID":"SV_3PHq8N243mxAr0W","Element":"PROJ","PrimaryAttribute":"CORE","SecondaryAttribute":null,"TertiaryAttribute":"1.1.0","Payload":{"ProjectCategory":"CORE","SchemaVersion":"1.1.0"}},{"SurveyID":"SV_3PHq8N243mxAr0W","Element":"QC","PrimaryAttribute":"Survey Question Count","SecondaryAttribute":"50","TertiaryAttribute":null,"Payload":null},{"SurveyID":"SV_3PHq8N243mxAr0W","Element":"RS","PrimaryAttribute":"RS_0dNjzg4We1jO6iy","SecondaryAttribute":null,"TertiaryAttribute":null,"Payload":null},{"SurveyID":"SV_3PHq8N243mxAr0W","Element":"SCO","PrimaryAttribute":"Scoring","SecondaryAttribute":null,"TertiaryAttribute":null,"Payload":{"ScoringCategories":[],"ScoringCategoryGroups":[],"ScoringSummaryCategory":null,"ScoringSummaryAfterQuestions":0,"ScoringSummaryAfterSurvey":0,"DefaultScoringCategory":null,"AutoScoringCategory":null}},{"SurveyID":"SV_3PHq8N243mxAr0W","Element":"SO","PrimaryAttribute":"Survey Options","SecondaryAttribute":null,"TertiaryAttribute":null,"Payload":{"BackButton":"false","SaveAndContinue":"false","SurveyProtection":"PublicSurvey","BallotBoxStuffingPrevention":"false","NoIndex":"Yes","SecureResponseFiles":"true","SurveyExpiration":"None","SurveyTermination":"Redirect","Header":"<script src=\"https:\/\/assets.prolific.com\/assets\/js\/qualtrics\/qualtrics.min.js?rid=${e:\/\/Field\/ResponseID}&t=x1n-ehQmdS1XI_X983rUOfGjjtK7EPud4g9QgJkOhTo0pwMAFOPBNVA4c3fEF6c6M6Qju8bEJmiDWiliThO9dST9_bIFoAEhYKx7Y0WfqXEGutIDxZ3yw9VY\"><\/script>","Footer":"","ProgressBarDisplay":"None","PartialData":"+1 week","ValidationMessage":null,"PreviousButton":" <- ","NextButton":" -> ","SurveyTitle":"SR Study 1 -- Confabulation Mechanism (4x3)","SkinLibrary":"okstatebusiness","SkinType":"templated","Skin":{"brandingId":null,"templateId":"*base","overrides":{"colors":{"secondary":"#1400c0","primary":"#1400c0"},"contrast":1,"layout":{"spacing":0},"questionText":{"size":"21px"}}},"NewScoring":1,"SurveyMetaDescription":"A brief study about product recommendations","CollectGeoLocation":"false","ShowExportTags":"false","AnonymizeResponse":"Yes","EOSRedirectURL":"https:\/\/app.prolific.com\/submissions\/complete?cc=C1K7GBIH","EmailThankYou":"false","ThankYouEmailMessage":null,"ThankYouEmailMessageLibrary":null,"PageTransition":"slide","EOSMessage":null,"PasswordProtection":"No","RefererCheck":"No","BallotBoxStuffingPreventionBehavior":null,"BallotBoxStuffingPreventionMessage":null,"BallotBoxStuffingPreventionMessageLibrary":null,"BallotBoxStuffingPreventionURL":null,"RecaptchaV3":"false","ConfirmStart":false,"AutoConfirmStart":false,"RelevantID":"false","RelevantIDLockoutPeriod":"+30 days","UseCustomSurveyLinkCompletedMessage":null,"SurveyLinkCompletedMessage":null,"SurveyLinkCompletedMessageLibrary":null,"ResponseSummary":"No","EOSMessageLibrary":null,"ValidateMessage":"false","ValidationMessageLibrary":null,"InactiveSurvey":null,"PartialDeletion":null,"PartialDataCloseAfter":"LastActivity","InactiveMessageLibrary":null,"InactiveMessage":null,"AvailableLanguages":{"EN":[]},"headerMid":"","SurveyName":"SR Study 2 - Inoculation Earbuds (2026-04-16)","ProtectSelectionIds":true,"CustomStyles":{"customCSS":".Skin #Buttons {text-align:center;}\n.Skin .SkinInner {min-width: 850px!important;}\n.Skin .SkinInner {\npadding-top: 40px;\n}\n"}}},{"SurveyID":"SV_3PHq8N243mxAr0W","Element":"SQ","PrimaryAttribute":"QID1","SecondaryAttribute":null,"TertiaryAttribute":null,"Payload":{"QuestionText":"Browser Meta Info","QuestionType":"Meta","Selector":"Browser","Configuration":{"QuestionDescriptionOption":"UseText"},"Language":[],"DataExportTag":"browser_meta","Choices":{"1":{"Display":"Browser","TextEntry":1},"2":{"Display":"Version","TextEntry":1},"3":{"Display":"Operating System","TextEntry":1},"4":{"Display":"Screen Resolution","TextEntry":1},"5":{"Display":"Flash Version","TextEntry":1},"6":{"Display":"Java Support","TextEntry":1},"7":{"Display":"User Agent","TextEntry":1}},"QuestionID":"QID1"}},{"SurveyID":"SV_3PHq8N243mxAr0W","Element":"SQ","PrimaryAttribute":"QID10","SecondaryAttribute":"Please review the following products carefully. ${e:\/\/Field\/ProductTable} Take your time to revie...","TertiaryAttribute":null,"Payload":{"QuestionText":"<span style=\"font-size:19px;\">Please review the following products carefully.<\/span><br><br>${e:\/\/Field\/ProductTable}<br><span style=\"font-size:19px;\">Take your time to review the specifications before continuing.<\/span>","QuestionType":"DB","Selector":"TB","Configuration":{"QuestionDescriptionOption":"UseText"},"QuestionJS":"Qualtrics.SurveyEngine.addOnload(function()\n{\n\tvar tables = document.querySelectorAll('table');\n\ttables.forEach(function(table){\n\t\tvar tbody = table.querySelector('tbody');\n\t\tif (!tbody) {\n\t\t\tvar rows = Array.from(table.querySelectorAll('tr'));\n\t\t\tif (rows.length > 1) {\n\t\t\t\ttbody = document.createElement('tbody');\n\t\t\t\tfor (var i = 1; i < rows.length; i++) {\n\t\t\t\t\ttbody.appendChild(rows[i]);\n\t\t\t\t}\n\t\t\t\ttable.appendChild(tbody);\n\t\t\t}\n\t\t}\n\t\tif (tbody) {\n\t\t\tvar rows = Array.from(tbody.querySelectorAll('tr'));\n\t\t\t\/\/ Fisher-Yates shuffle\n\t\t\tfor (var i = rows.length - 1; i > 0; i--) {\n\t\t\t\tvar j = Math.floor(Math.random() * (i + 1));\n\t\t\t\tvar temp = rows[i];\n\t\t\t\trows[i] = rows[j];\n\t\t\t\trows[j] = temp;\n\t\t\t}\n\t\t\t\/\/ Re-append in shuffled order\n\t\t\trows.forEach(function(row){ tbody.appendChild(row); });\n\t\t\t\/\/ Record the shuffled order to embedded data\n\t\t\tvar brandOrder = rows.map(function(row){\n\t\t\t\tvar firstCell = row.querySelector('td');\n\t\t\t\treturn firstCell ? firstCell.textContent.trim() : '?';\n\t\t\t});\n\t\t\tQualtrics.SurveyEngine.setEmbeddedData('ProductDisplayOrder', brandOrder.join('|'));\n\t\t}\n\t});\n});\n\nQualtrics.SurveyEngine.addOnReady(function()\n{\n\t\/*Place your JavaScript here to run when the page is fully displayed*\/\n\n});\n\nQualtrics.SurveyEngine.addOnUnload(function()\n{\n\t\/*Place your JavaScript here to run when the page is unloaded*\/\n\n});","Language":[],"DataExportTag":"product_table","QuestionID":"QID10","DataVisibility":{"Private":false,"Hidden":false},"QuestionDescription":"Please review the following products carefully. ${e:\/\/Field\/ProductTable} Take your time to revie...","ChoiceOrder":[],"NextChoiceId":1,"NextAnswerId":1}},{"SurveyID":"SV_3PHq8N243mxAr0W","Element":"SQ","PrimaryAttribute":"QID11","SecondaryAttribute":null,"TertiaryAttribute":null,"Payload":{"QuestionText":"<span style=\"font-size:19px;\">You also received the following recommendation from an AI shopping assistant:<\/span><br><br>${e:\/\/Field\/AIRecommendation}","QuestionType":"DB","Selector":"TB","Configuration":{"QuestionDescriptionOption":"UseText"},"Language":[],"QuestionText_Unsafe":"<span style=\"font-size:19px;\">You also received the following recommendation from an AI shopping assistant:<\/span><br><br>${e:\/\/Field\/AIRecommendation}","QuestionID":"QID11"}},{"SurveyID":"SV_3PHq8N243mxAr0W","Element":"SQ","PrimaryAttribute":"QID12","SecondaryAttribute":null,"TertiaryAttribute":null,"Payload":{"QuestionText":"Timing","QuestionType":"Timing","Selector":"PageTimer","Configuration":{"QuestionDescriptionOption":"UseText","MinSeconds":3,"MaxSeconds":"0"},"Choices":{"1":{"Display":"First Click"},"2":{"Display":"Last Click"},"3":{"Display":"Page Submit"},"4":{"Display":"Click Count"}},"Language":[],"DataExportTag":"timer_comprehension","QuestionID":"QID12"}},{"SurveyID":"SV_3PHq8N243mxAr0W","Element":"SQ","PrimaryAttribute":"QID13","SecondaryAttribute":null,"TertiaryAttribute":null,"Payload":{"QuestionText":"Which sport earbuds have the <strong>highest water resistance (IP rating)<\/strong>?","QuestionType":"MC","Selector":"SAVR","SubSelector":"TX","Configuration":{"QuestionDescriptionOption":"UseText"},"Choices":{"1":{"Display":"Beats Fit Pro"},"2":{"Display":"JBL Endurance Race"},"3":{"Display":"Shokz OpenRun Pro 2"},"4