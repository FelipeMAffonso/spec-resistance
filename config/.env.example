# Spec Resistance — environment-variable template.
#
# Copy this file to config/.env and fill in your own keys. The actual
# config/.env file is gitignored and must NEVER be committed.

# ─── Required for reproducing the main 382K-trial corpus ──────────────
ANTHROPIC_API_KEY=sk-ant-...             # Anthropic (Claude Haiku 4.5, Claude Sonnet 4.6)
OPENAI_API_KEY=sk-...                    # OpenAI (GPT-4o, 4o-mini, 4.1-mini, 4.1-nano, 5-mini)
GOOGLE_API_KEY=AIza...                   # Google AI Studio (Gemini 2.0/2.5/3 Flash + Gemma)
GOOGLE_VERTEX_API_KEY=AQ.ab...           # Google Vertex AI Express Mode (acceleration)
OPENROUTER_API_KEY=sk-or-v1-...          # OpenRouter (Llama, DeepSeek, Qwen, Kimi)

# ─── Required for open-weight probing and steering (Modal) ────────────
HUGGINGFACE_TOKEN=hf_...                 # HuggingFace (for Qwen, Mistral, Gemma base weights)
                                         # Modal scripts now read this from the environment.

# ─── Required for cross-architecture base-vs-instruct replication ─────
TOGETHER_API_KEY=...                     # Together AI (Qwen, Mistral, Gemma base models)
                                         # Optional if you skip the cross-architecture base
                                         # variants and use only the Google/OpenAI base lineup.

# ─── Required for Study 3 and the human-study anonymisation pipeline ──
QUALTRICS_API_TOKEN=...                  # Qualtrics REST API token (PDX1 data centre)
                                         # Used by nature-rr/scripts/qualtrics/*.py and
                                         # anonymise_human_studies.py.

# ─── Optional observability ───────────────────────────────────────────
# OPENAI_ORG=org-...                     # optional OpenAI org pinning
# LANGFUSE_PUBLIC_KEY=...                # optional: LLM call tracing
# LANGFUSE_SECRET_KEY=...
# LANGFUSE_HOST=https://cloud.langfuse.com

# ─── Study 3 Worker administration (do not commit) ────────────────────
# The Cloudflare Worker uses its own secret store. See
# nature-rr/study3-chatbot/worker/.env.admin (gitignored) for the
# X-Admin-Token required by /export and /sessions admin endpoints.
